{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "esnext",
    "target": "ES2020",

    "types": ["node"],

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}
